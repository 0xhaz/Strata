# ── web (Vercel) ──

# Owner/settler key — powers the server-side KYC "Get approved" button (setKyc is onlyOwner).
# Same value as mantle-vault/.env PRIVATE_KEY (the deployer wallet). Testnet only.
MANTLE_AGENT_KEY=

# Live-feed bridge (optional) — lets the deployed /live page stream your local agent.
# Pick any secret string; it must match LIVE_INGEST_TOKEN on the agent side.
LIVE_INGEST_TOKEN=

# Shared store for the live feed across serverless instances.
# Auto-injected when you add the Vercel KV / Upstash Redis storage add-on:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
