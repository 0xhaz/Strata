# ── tranche-strategy (the agent) ──

# Settler key for on-chain settle(). Falls back to mantle-vault/.env PRIVATE_KEY if unset.
MANTLE_AGENT_KEY=

# Live-feed bridge (optional) — push the agent's feed to the deployed dashboard each cycle,
# so its /live page streams without your laptop being the source.
LIVE_FEED_URL=https://strata-web-delta.vercel.app
LIVE_INGEST_TOKEN=
